---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Rodinná farma na Ponikoch – chov koní, kôz a záchrana zvierat' } = Astro.props;
const siteUrl = Astro.site?.href ?? 'https://koragold.sk';
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteUrl}images/farm-1.jpg`} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="sk_SK" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Farm",
      "name": "FARMA KORAGOLD-ABM",
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Poniky",
        "postalCode": "976 33",
        "addressCountry": "SK"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 48.71, "longitude": 19.28 },
      "telephone": "+421950466433",
      "url": siteUrl,
      "sameAs": ["https://www.facebook.com/groups/1195825154613635/"]
    })} />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>

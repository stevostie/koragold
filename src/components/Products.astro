---
import ScatterIcons from './ScatterIcons.astro';
// Reálne produktové fotky doplň do public/images a nastav `photo`.
// Kým je `photo` null, zobrazí sa zreteľný placeholder.
const products = [
  {
    photo: null,            // napr. '/images/produkt-mlieko.jpg'
    badge: '/images/logo-mlieko.png',
    title: 'Kozie mlieko',
    tag: 'Nepasterizované',
    description: 'Čerstvé kozie mlieko od našich kôz chovaných pôvodným spôsobom. Prirodzená chuť, tak ako má byť.',
  },
  {
    photo: null,            // napr. '/images/produkt-syr.jpg'
    badge: '/images/logo-syr.png',
    title: 'Kozí syr',
    tag: 'Z nepasterizovaného mlieka',
    description: 'Poctivý kozí syr vyrobený z nášho mlieka. Jemná chuť, žiadne zbytočné prísady.',
  },
];
---

<section id="produkty" class="relative py-20 md:py-24 px-6 bg-cream-deep/50 overflow-hidden">
  <ScatterIcons type="milk" />
  <div class="relative max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="eyebrow text-wine text-xs mb-3">Z kozej farmy</p>
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-ink mb-5">Produkty z kozieho mlieka</h2>
      <div class="stamp-divider text-wheat-dark mb-6">
        <span class="rule"></span><span class="dot"></span><span class="rule"></span>
      </div>
      <p class="text-lg text-ink-soft max-w-2xl mx-auto leading-relaxed">
        Domáce produkty od našich kôz — vyrobené s rovnakou starostlivosťou, akú venujeme zvieratám.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-8 max-w-3xl mx-auto">
      {products.map((p) => (
        <div class="bg-cream-card rounded-xl border border-ink/12 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden flex flex-col">
          <div class="relative aspect-[4/3] overflow-hidden">
            {p.photo ? (
              <img src={p.photo} alt={`${p.title} – FARMA KORAGOLD-ABM`} width="800" height="600" loading="lazy" decoding="async"
                   class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-sage/25 via-cream-deep to-wheat/25 flex flex-col items-center justify-center text-sage-dark" role="img" aria-label={`${p.title} – fotka bude doplnená`}>
                <svg class="w-10 h-10 mb-2 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 8a2 2 0 012-2h2l1.5-2h7L18 6h2a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"></path>
                  <circle cx="12" cy="12.5" r="3.3" stroke-width="1.6"></circle>
                </svg>
                <span class="eyebrow text-[10px]">Fotka čoskoro</span>
              </div>
            )}
            <!-- brand stamp accent -->
            <img src={p.badge} alt="" aria-hidden="true" width="64" height="64"
                 class="absolute bottom-3 right-3 w-14 h-14 drop-shadow" loading="lazy" />
          </div>

          <div class="p-7 text-center flex flex-col items-center">
            <span class="inline-block eyebrow text-[10px] text-sage-dark bg-sage/15 border border-sage/30 rounded-full px-3 py-1 mb-3">{p.tag}</span>
            <h3 class="font-heading text-2xl font-bold text-ink mb-3">{p.title}</h3>
            <p class="text-ink-soft leading-relaxed">{p.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="#kontakt" class="prod-cta btn-vintage bg-sage hover:bg-sage-dark text-cream py-3.5 px-8 text-sm shadow-sm hover:scale-105">
        Mám záujem
      </a>
    </div>
  </div>
</section>

<style>
  .prod-cta:focus-visible { outline: 2px solid var(--color-wine); outline-offset: 2px; }
</style>

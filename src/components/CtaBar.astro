<div id="cta-bar" class="fixed bottom-0 left-0 right-0 z-40 bg-ink/95 backdrop-blur-sm border-t border-wheat/25 transform translate-y-full transition-transform duration-300">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <div class="hidden sm:block">
      <p class="text-cream font-display font-bold tracking-wider text-sm">FARMA KORAGOLD-ABM</p>
      <p class="text-wheat text-xs">Poniky · Jazdy a kozie produkty</p>
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto">
      <a href="tel:+421950466433" class="btn-vintage flex-1 sm:flex-none py-2.5 px-6 bg-wine text-cream hover:bg-wine-dark text-sm">
        Zavolať
      </a>
      <a href="#kontakt" class="btn-vintage flex-1 sm:flex-none py-2.5 px-6 border border-wheat/50 text-wheat hover:bg-wheat/10 text-sm">
        Kontakt
      </a>
    </div>
  </div>
</div>

<script is:inline>
  const ctaBar = document.getElementById('cta-bar');
  if (ctaBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          ctaBar.classList.remove('translate-y-full');
        } else {
          ctaBar.classList.add('translate-y-full');
        }
      },
      { threshold: 0 }
    );
    const hero = document.getElementById('hero');
    if (hero) observer.observe(hero);
  }
</script>

---
---

<section class="py-20 px-6 bg-cream">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-brown mb-4">
        Kontakt & Lokalita
      </h2>
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-gold"></div>
        <div class="w-3 h-3 bg-gold rotate-45"></div>
        <div class="h-px w-12 bg-gold"></div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Contact info -->
      <div class="space-y-8">
        <!-- Location -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-brown mb-1">Lokalita</h3>
            <p class="text-brown-light">Poniky, okres Banská Bystrica</p>
            <p class="text-brown-light text-sm">Banskobystrický kraj, Slovensko</p>
          </div>
        </div>

        <!-- Facebook -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-blue-600/10 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-brown mb-1">Facebook skupina</h3>
            <p class="text-brown-light mb-2">760 členov • Aktívna komunita</p>
            <a 
              href="https://www.facebook.com/groups/1195825154613635/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-medium transition-colors"
            >
              Pripojiť sa k skupine
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- About -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-green-folk/10 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-green-folk" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-brown mb-1">O farme</h3>
            <p class="text-brown-light">Rodinná farma budovaná s láskou k prírode a zvieratám. Venujeme sa chovu koní, kôz a záchrane zvierat.</p>
          </div>
        </div>
      </div>

      <!-- Map placeholder / decorative -->
      <div class="relative">
        <div class="aspect-square bg-gradient-to-br from-green-folk/20 to-earth/30 rounded-2xl border border-gold/20 overflow-hidden flex items-center justify-center">
          <div class="text-center p-8">
            <svg class="w-20 h-20 text-green-folk/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
            </svg>
            <p class="font-heading text-2xl font-bold text-brown mb-2">Poniky</p>
            <p class="text-brown-light">Banskobystrický kraj</p>
            <p class="text-brown-light text-sm mt-1">Slovensko</p>
            
            <!-- Decorative compass -->
            <div class="mt-6 flex items-center justify-center gap-2 text-gold">
              <span class="text-sm font-bold">S</span>
              <div class="w-px h-4 bg-gold/50"></div>
              <span class="text-sm">J</span>
              <div class="w-px h-4 bg-gold/50"></div>
              <span class="text-sm">V</span>
              <div class="w-px h-4 bg-gold/50"></div>
              <span class="text-sm">Z</span>
            </div>
          </div>
        </div>
        
        <!-- Corner decorations -->
        <div class="absolute -top-2 -right-2 w-8 h-8 border-t-3 border-r-3 border-gold/40 rounded-tr-lg"></div>
        <div class="absolute -bottom-2 -left-2 w-8 h-8 border-b-3 border-l-3 border-gold/40 rounded-bl-lg"></div>
      </div>
    </div>
  </div>
</section>
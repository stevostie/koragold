---
---

<section id="kontakt" class="py-20 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="eyebrow text-wine text-xs mb-3">Ozvite sa nám</p>
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-ink mb-5">Kontakt &amp; lokalita</h2>
      <div class="stamp-divider text-wheat-dark">
        <span class="rule"></span><span class="dot"></span><span class="rule"></span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div class="space-y-7">
        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-wine/10 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-wine" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-ink mb-1">Telefón</h3>
            <a href="tel:+421950466433" class="text-lg text-ink-soft hover:text-wine transition-colors">0950 466 433 – Štefan</a>
            <p class="text-ink-soft text-sm mt-1">Jazdy aj produkty vybavujeme telefonicky.</p>
          </div>
        </div>

        <!-- Address -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-sage/15 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-sage-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-ink mb-1">Kde nás nájdete</h3>
            <p class="text-ink-soft">976 33 Poniky, okres Banská Bystrica</p>
            <p class="text-ink-soft text-sm">Banskobystrický kraj, Slovensko</p>
          </div>
        </div>

        <!-- Visits -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-wheat/15 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-wheat-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-ink mb-1">Návštevy</h3>
            <p class="text-ink-soft">Po dohode telefonicky</p>
            <p class="text-ink-soft text-sm">Najlepšie cez víkend</p>
          </div>
        </div>

        <!-- Facebook -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-ink/5 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-ink" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-xl font-bold text-ink mb-1">Facebook skupina</h3>
            <p class="text-ink-soft mb-2">Aktívna komunita priateľov farmy</p>
            <a href="https://www.facebook.com/groups/1195825154613635/" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-wine hover:text-wine-dark font-medium transition-colors">
              Pripojiť sa k skupine
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="relative">
        <div class="aspect-square rounded-lg border border-ink/15 overflow-hidden shadow-sm">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d212847.5!2d19.28!3d48.71!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDjCsDQyJzM2LjAiTiAxOcKwMTYnNDguMCJF!5e0!3m2!1ssk!2ssk!4v1"
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="Mapa - Poniky, Banská Bystrica"></iframe>
        </div>
        <div class="absolute -top-2 -right-2 w-8 h-8 border-t-2 border-r-2 border-wheat/50"></div>
        <div class="absolute -bottom-2 -left-2 w-8 h-8 border-b-2 border-l-2 border-wheat/50"></div>
      </div>
    </div>
  </div>
</section>

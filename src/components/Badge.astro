---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<!-- Vintage farm stamp, echoing the KORAGOLD-ABM product label -->
<svg
  class={className}
  viewBox="0 0 240 240"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="FARMA KORAGOLD-ABM, Poniky"
>
  <defs>
    <path id="badge-top" d="M 40,120 A 80,80 0 0 0 200,120" fill="none" />
    <!-- one wheat ear pointing up, base at 0,0 -->
    <g id="wheat-ear">
      <line x1="0" y1="0" x2="0" y2="-40" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
      <g fill="currentColor">
        <ellipse cx="-5.5" cy="-9" rx="3.4" ry="6" transform="rotate(38 -5.5 -9)" />
        <ellipse cx="5.5" cy="-9" rx="3.4" ry="6" transform="rotate(-38 5.5 -9)" />
        <ellipse cx="-5" cy="-18" rx="3.2" ry="5.6" transform="rotate(38 -5 -18)" />
        <ellipse cx="5" cy="-18" rx="3.2" ry="5.6" transform="rotate(-38 5 -18)" />
        <ellipse cx="-4.2" cy="-26" rx="3" ry="5" transform="rotate(38 -4.2 -26)" />
        <ellipse cx="4.2" cy="-26" rx="3" ry="5" transform="rotate(-38 4.2 -26)" />
        <ellipse cx="0" cy="-34" rx="3" ry="6" />
        <ellipse cx="0" cy="-42" rx="2.4" ry="4.6" />
      </g>
    </g>
  </defs>

  <!-- rings -->
  <circle cx="120" cy="120" r="116" fill="var(--color-label)" stroke="var(--color-ink)" stroke-width="6" />
  <circle cx="120" cy="120" r="104" fill="none" stroke="var(--color-wine)" stroke-width="1.5" />
  <circle cx="120" cy="120" r="98" fill="none" stroke="var(--color-ink)" stroke-width="2" />

  <!-- top curved text -->
  <text fill="var(--color-ink)" font-family="var(--font-display)" font-weight="800"
        font-size="17" letter-spacing="1.5" text-anchor="middle">
    <textPath href="#badge-top" startOffset="50%">FARMA KORAGOLD-ABM</textPath>
  </text>

  <!-- PONIKY straight under -->
  <text x="120" y="74" fill="var(--color-wine)" font-family="var(--font-display)" font-weight="700"
        font-size="13" letter-spacing="4" text-anchor="middle">PONIKY</text>

  <!-- central crossed wheat sheaf -->
  <g color="var(--color-ink)">
    <use href="#wheat-ear" transform="translate(120 158) rotate(-20)" />
    <use href="#wheat-ear" transform="translate(120 158) rotate(20)" />
    <use href="#wheat-ear" transform="translate(120 158)" />
  </g>

  <!-- bottom diamonds -->
  <g fill="var(--color-ink)" transform="translate(120 188)">
    <rect x="-13" y="-3" width="6" height="6" transform="rotate(45 -10 0)" />
    <rect x="-3" y="-3.5" width="7" height="7" transform="rotate(45 0 0)" fill="var(--color-wine)" />
    <rect x="7" y="-3" width="6" height="6" transform="rotate(45 10 0)" />
  </g>
</svg>

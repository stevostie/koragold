---
// Subtle vintage divider — a thin centred ornament, not a full-width band
---

<div class="flex items-center justify-center py-2" aria-hidden="true">
  <div class="flex items-center gap-3 text-ink/35">
    <span class="h-px w-16 md:w-24 bg-current"></span>
    <svg class="w-6 h-6 text-wine/70" viewBox="0 0 24 24" fill="currentColor">
      <rect x="9.5" y="9.5" width="5" height="5" transform="rotate(45 12 12)" />
    </svg>
    <span class="h-px w-16 md:w-24 bg-current"></span>
  </div>
</div>

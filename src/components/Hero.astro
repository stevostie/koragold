---
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
  <!-- Background image -->
  <img src="/images/farm-1.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
  
  <!-- Dark overlay for readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary/80 via-primary/70 to-brown/90"></div>
  
  <!-- Decorative SVG pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="folk-dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="2" fill="#C8A84E" />
          <circle cx="0" cy="0" r="1.5" fill="#C8A84E" />
          <circle cx="40" cy="0" r="1.5" fill="#C8A84E" />
          <circle cx="0" cy="40" r="1.5" fill="#C8A84E" />
          <circle cx="40" cy="40" r="1.5" fill="#C8A84E" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#folk-dots)" />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Gold decorative line -->
    <div class="flex items-center justify-center gap-4 mb-6 opacity-0 animate-fade-in-up">
      <div class="h-px w-16 bg-gold"></div>
      <svg class="w-8 h-8 text-gold" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 2l3 8h8l-6.5 5 2.5 8L16 18l-7 5 2.5-8L5 10h8z" />
      </svg>
      <div class="h-px w-16 bg-gold"></div>
    </div>

    <!-- Main title -->
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold text-cream mb-4 opacity-0 animate-fade-in-up drop-shadow-lg">
      FARMA<br/>
      <span class="text-gold">KORAGOLD-ABM</span>
    </h1>

    <!-- Subtitle -->
    <p class="font-heading text-xl md:text-2xl text-gold-light mb-6 italic opacity-0 animate-fade-in-up animation-delay-200">
      Rodinná farma v srdci Poník
    </p>

    <!-- Description -->
    <p class="text-lg md:text-xl text-cream/90 mb-10 max-w-2xl mx-auto opacity-0 animate-fade-in-up animation-delay-400">
      Venujeme sa chovu koní, kôz a záchrane zvierat. Budujeme s láskou k prírode a tradíciám nášho kraja.
    </p>

    <!-- CTA Button -->
    <div class="opacity-0 animate-fade-in-up animation-delay-600">
      <a 
        href="https://www.facebook.com/groups/1195825154613635/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-gold hover:bg-gold-dark text-brown font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 hover:scale-105 shadow-lg hover:shadow-xl"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Navštívte nás na Facebooku
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in-up animation-delay-600">
      <div class="w-6 h-10 border-2 border-cream/50 rounded-full flex justify-center">
        <div class="w-1.5 h-3 bg-cream/70 rounded-full mt-2 animate-bounce"></div>
      </div>
    </div>
  </div>
</section>
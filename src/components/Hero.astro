---
import Badge from './Badge.astro';
---

<section id="hero" class="relative min-h-[92vh] flex items-center justify-center overflow-hidden">
  <!-- Background image with Ken Burns effect -->
  <img src="/images/farm-1.jpg" alt="" class="absolute inset-0 w-full h-full object-cover animate-ken-burns" aria-hidden="true" />

  <!-- Warm charcoal overlay for readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-ink/75 via-ink/60 to-ink/90"></div>

  <!-- Inner vintage frame -->
  <div class="absolute inset-4 md:inset-6 border border-label/25 pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto pt-16">
    <!-- Badge -->
    <div class="flex justify-center mb-7 opacity-0 animate-fade-in-up">
      <Badge class="w-28 h-28 md:w-36 md:h-36 drop-shadow-xl" />
    </div>

    <p class="eyebrow text-wheat text-xs md:text-sm mb-4 opacity-0 animate-fade-in-up animation-delay-200">
      Rodinná farma na Ponikoch
    </p>

    <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-bold text-cream mb-5 leading-tight opacity-0 animate-fade-in-up animation-delay-200 drop-shadow">
      Kone, kozy a domov<br/>pre zachránené zvieratá
    </h1>

    <p class="font-body text-lg md:text-xl text-cream/85 mb-9 max-w-xl mx-auto opacity-0 animate-fade-in-up animation-delay-400">
      Jazdy na koňoch pre celú rodinu a poctivé produkty z kozieho mlieka —
      v srdci Banskobystrického kraja.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-in-up animation-delay-600">
      <a href="tel:+421950466433"
         class="btn-vintage bg-wine hover:bg-wine-dark text-cream py-4 px-8 text-base shadow-lg hover:scale-105">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        Zavolať · 0950 466 433
      </a>
      <a href="#jazdy"
         class="btn-vintage border-2 border-cream/40 hover:border-wheat text-cream hover:text-wheat py-4 px-8 text-base hover:scale-105">
        Naše jazdy
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in-up animation-delay-600">
    <div class="w-6 h-10 border-2 border-cream/40 rounded-full flex justify-center">
      <div class="w-1.5 h-3 bg-cream/60 rounded-full mt-2 animate-bounce"></div>
    </div>
  </div>
</section>

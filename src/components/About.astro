---
const features = [
  {
    image: '/images/farm-2.jpg',
    title: 'Chov koní',
    description: 'Naše kone sú súčasťou rodiny. Staráme sa o ne s láskou a ponúkame jazdecké zážitky v krásnom prostredí Poník.'
  },
  {
    image: '/images/kozy.jpg',
    title: 'Chov kôz',
    description: 'Naše kozy nám dávajú mlieko a radosť. Pestujeme overený spôsob chovu v súlade s prírodou.'
  },
  {
    image: '/images/farm-5.jpg',
    title: 'Záchrana zvierat',
    description: 'Pomáhame zvieratám v núdzi. Každé zviera si zaslúži láskavý domov a starostlivosť.'
  }
];
---

<section class="py-20 px-6 bg-cream">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-brown mb-4">
        O našej farme
      </h2>
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-gold"></div>
        <div class="w-3 h-3 bg-gold rotate-45"></div>
        <div class="h-px w-12 bg-gold"></div>
      </div>
      <p class="text-lg text-brown-light max-w-2xl mx-auto">
        V Ponikoch budujeme miesto, kde tradičný chov ide ruka v ruke s rešpektom k zvieratám a krajine. Stretneš tu kone, kozy aj zachránených tvorov, o ktorých sa staráme ako o rodinu.
      </p>
    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-gold/20 group">
          <div class="relative h-48 overflow-hidden">
            <img
              src={feature.image}
              alt={feature.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brown/30 to-transparent"></div>
          </div>
          <div class="p-8">
          <h3 class="font-heading text-2xl font-bold text-brown mb-3">
            {feature.title}
          </h3>
          <p class="text-brown-light leading-relaxed">
            {feature.description}
          </p>
          <!-- Decorative bottom border -->
          <div class="mt-6 h-1 w-16 bg-gradient-to-r from-gold to-primary rounded-full"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
---
const links = [
  { href: '#o-farme', label: 'O farme' },
  { href: '#jazdy', label: 'Jazdy na koňoch' },
  { href: '#produkty', label: 'Kozie produkty' },
  { href: '#pribeh', label: 'Príbeh' },
  { href: '#galeria', label: 'Galéria' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<header id="site-nav" class="nav nav-top fixed top-0 left-0 right-0 z-50">
  <!-- top scrim for readability over hero -->
  <div class="nav-scrim absolute inset-0 -z-10 bg-gradient-to-b from-ink/75 via-ink/35 to-transparent pointer-events-none"></div>

  <nav class="max-w-6xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="#hero" class="flex items-center gap-3 group focus-ring rounded">
      <img src="/images/logo-brand.png" alt="Logo farmy KORAGOLD-ABM" width="56" height="56" class="w-10 h-10 md:w-14 md:h-14 shrink-0 drop-shadow-sm" />
      <span class="leading-tight">
        <span class="brand-main block font-display font-extrabold tracking-wider text-sm md:text-base">KORAGOLD-ABM</span>
        <span class="brand-sub block font-display text-[10px] md:text-xs tracking-[0.25em]">FARMA · PONIKY</span>
      </span>
    </a>

    <div class="hidden lg:flex items-center gap-7">
      {links.map((l) => (
        <a href={l.href} class="navlink font-body text-sm transition-colors focus-ring rounded px-1 py-0.5">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <a href="tel:+421950466433"
         class="btn-vintage bg-wine hover:bg-wine-dark text-cream text-xs md:text-sm py-2.5 px-4 md:px-5 shadow-sm focus-ring">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <span class="hidden sm:inline">0950 466 433</span>
        <span class="sm:hidden">Volať</span>
      </a>

      <!-- hamburger (mobile/tablet) -->
      <button id="nav-toggle" type="button" class="lg:hidden navlink p-2 -mr-1 focus-ring rounded" aria-label="Otvoriť menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- mobile menu panel -->
  <div id="mobile-menu" class="lg:hidden hidden bg-cream/98 backdrop-blur-sm border-t border-ink/10 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col">
      {links.map((l) => (
        <a href={l.href} class="mobile-link font-body text-ink-soft hover:text-wine py-3 border-b border-ink/5 last:border-0 focus-ring rounded">{l.label}</a>
      ))}
    </div>
  </div>
</header>

<style>
  /* transparent (over hero) state */
  .nav-top .brand-main { color: var(--color-cream); }
  .nav-top .brand-sub  { color: var(--color-wheat); }
  .nav-top .navlink    { color: var(--color-cream); }
  .nav-top .navlink:hover { color: var(--color-wheat); }
  .nav-top .nav-scrim  { opacity: 1; }

  /* scrolled state */
  .nav-scrolled { background-color: color-mix(in srgb, var(--color-cream) 95%, transparent); backdrop-filter: blur(4px); border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent); box-shadow: 0 2px 10px rgba(43,39,34,0.06); }
  .nav-scrolled .brand-main { color: var(--color-ink); }
  .nav-scrolled .brand-sub  { color: var(--color-wine); }
  .nav-scrolled .navlink    { color: var(--color-ink-soft); }
  .nav-scrolled .navlink:hover { color: var(--color-wine); }
  .nav-scrolled .nav-scrim  { opacity: 0; }

  .nav-scrim { transition: opacity 0.3s ease; }

  .focus-ring:focus-visible { outline: 2px solid var(--color-wine); outline-offset: 2px; }
  .nav-top .focus-ring:focus-visible { outline-color: var(--color-wheat); }
</style>

<script is:inline>
  (function () {
    const nav = document.getElementById('site-nav');
    const onScroll = () => {
      if (window.scrollY > 40) { nav.classList.add('nav-scrolled'); nav.classList.remove('nav-top'); }
      else { nav.classList.add('nav-top'); nav.classList.remove('nav-scrolled'); }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const setOpen = (open) => {
      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Zavrieť menu' : 'Otvoriť menu');
    };
    toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  })();
</script>
